    "@types/react": "^18.2.25",
    "@types/react-dom": "^18.2.10",
    "@types/styled-components": "^5.1.28",
    "cz-conventional-changelog": "^3.3.0",
    "storybook": "7.6.4",
    "typescript": "^5.2.2"
  },
  "config": {
